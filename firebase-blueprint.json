{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Talent or Client profile data",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["talent", "client"] },
        "bio": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "rate": { "type": "number" },
        "experience": { "type": "integer" },
        "avatarUrl": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["userId", "fullName", "role", "email"]
    },
    "Job": {
      "title": "Job Posting",
      "description": "Job details posted by clients",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "budget": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "description", "status"]
    },
    "Application": {
      "title": "Job Application",
      "description": "Talent application for a job",
      "type": "object",
      "properties": {
        "applicationId": { "type": "string" },
        "jobId": { "type": "string" },
        "talentId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "coverLetter": { "type": "string" }
      },
      "required": ["jobId", "talentId", "status"]
    }
  },
  "firestore": {
    "profiles/{userId}": {
      "schema": "Profile",
      "description": "User profile documents"
    },
    "jobs/{jobId}": {
      "schema": "Job",
      "description": "Job posting documents"
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "Job application documents"
    }
  }
}
